{
  "ignorePatterns": [
    {
      "pattern": "^https?://(localhost|127\\.0\\.0\\.1|0\\.0\\.0\\.0|192\\.168\\.|10\\.|172\\.(1[6-9]|2[0-9]|3[01])\\.)(:\\d+)?(/.*)?$"
